# Local PostgreSQL connection string (the app's database).
# Matches the Docker command in the README. Load schema: psql "$DATABASE_URL" -f db/schema.sql
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transitops

# Auth — secret used to sign JWT session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string

# AI provider key (Groq — OpenAI-compatible). Get one at https://console.groq.com/keys
GROQ_API_KEY=your-groq-key

# Email (optional) — license reminders send via Resend when set; otherwise dry-run preview.
# RESEND_API_KEY=your-resend-key
# RESEND_FROM=TransitOps <onboarding@resend.dev>
