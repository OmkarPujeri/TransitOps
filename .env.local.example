# Supabase — from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider key (Groq — OpenAI-compatible). Get one at https://console.groq.com/keys
GROQ_API_KEY=your-groq-key

# Email (optional) — license reminders send via Resend when set; otherwise dry-run preview.
# RESEND_API_KEY=your-resend-key
# RESEND_FROM=TransitOps <onboarding@resend.dev>
